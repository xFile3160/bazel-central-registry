+
+def _rewrite_standalone_protoc_plugin_deps(args):
+    name = args.get("name")
+    if name not in _PROTOC_PLUGIN_DEPS:
+        return args
+    args["deps"] = [
+        dep
+        for dep in args.get("deps", [])
+        if dep != "@com_google_protobuf//:protoc_lib"
+    ] + _PROTOC_PLUGIN_DEPS[name]
+    return args
+
